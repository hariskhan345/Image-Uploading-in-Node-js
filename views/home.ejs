<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Professional File Upload</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Inter", sans-serif;
      }

      body {
        background-color: #f4f7f9;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
      }

      .upload-container {
        background: #ffffff;
        padding: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        width: 100%;
        max-width: 450px;
        text-align: center;
      }

      .upload-header h1 {
        font-size: 1.5rem;
        color: #1e293b;
        margin-bottom: 8px;
      }

      .upload-header p {
        font-size: 0.875rem;
        color: #64748b;
        margin-bottom: 24px;
      }

      /* File Input Styling */
      .file-input-wrapper {
        position: relative;
        margin-bottom: 20px;
      }

      #file-input {
        width: 100%;
        height: 150px;
        opacity: 0;
        cursor: pointer;
        z-index: 2;
        position: relative;
      }

      .file-label {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: 2px dashed #cbd5e1;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        transition: all 0.3s ease;
        background: #f8fafc;
      }

      #file-input:hover + .file-label {
        border-color: #3b82f6;
        background: #eff6ff;
      }

      .file-label .icon {
        font-size: 2rem;
        margin-bottom: 10px;
      }

      .file-label .text {
        font-size: 0.9rem;
        color: #475569;
      }

      /* Submit Button */
      .upload-btn {
        width: 100%;
        padding: 12px;
        background-color: #3b82f6;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: background 0.3s ease;
      }

      .upload-btn:hover {
        background-color: #2563eb;
      }
    </style>
  </head>
  <body>
    <div class="upload-container">
      <div class="upload-header">
        <h1>Upload Profile Image</h1>
        <p>PNG, JPG or GIF (Max. 5MB)</p>
      </div>

      <form
        action="/upload"
        method="POST"
        enctype="multipart/form-data"
        class="upload-form"
      >
        <div class="file-input-wrapper">
          <input type="file" name="profileImage" id="file-input" required />
          <label for="file-input" class="file-label">
            <span class="icon">📁</span>
            <span class="text">Choose a file or drag it here</span>
          </label>
        </div>
        <button type="submit" class="upload-btn">Upload Now</button>
      </form>
    </div>
  </body>
</html>
